# ── Required ───────────────────────────────────────────────────────────────────

# Discord bot token (from Discord Developer Portal)
TOKEN=

# SQLAlchemy database connection string
# Examples:
#   SQLite  : sqlite:///ffa_bot.db
#   Postgres: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# Discord guild (server) ID where the bot operates
GUILD_ID=

# ── Channel IDs ────────────────────────────────────────────────────────────────

# Channel where the registration embed is posted
REGISTER_CHANNEL_ID=

# Channel where the check-in embed is posted
CHECKIN_CHANNEL_ID=

# Channel where lobby-division notifications are sent
DIVIDE_LOBBY_CHANNEL_ID=

# Channel where per-lobby result-entry embeds are posted (admins enter scores here)
RESULT_CHANNEL_ID=

# ── Role IDs ───────────────────────────────────────────────────────────────────

# Role that is @mentioned when a match opens (instead of @everyone)
SHOWMATCH_ROLE_ID=

# Role allowed to view per-lobby channels alongside admins (e.g. referee/judge role)
JUDGE_ROLE_ID=

# ── Category IDs ──────────────────────────────────────────────────────────────

# Discord category under which per-lobby voice/text channels are created
LOBBY_CATEGORY_ID=

# ── Match settings ─────────────────────────────────────────────────────────────

# Minimum number of registered players required to proceed with a match (default: 6)
MIN_PLAYERS_REQUIRED=
